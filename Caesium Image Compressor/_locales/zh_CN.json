            "save": "保存设置"
        },
        "dialog": {
            "success": {
                "title": "压缩完成！",
                "description": "已经压缩 <span style='color: var(--color-positive)'>{{ count }}</span> 个图片。你可以在 Eagle 中选择其他图片继续压缩。",
                "cancel": "关闭",
                "ok": "确认"
            }
        }
    },
    "footer": {
        "setting": {
            "title": "压缩设置",
            "hint": "点击这里进行压缩设置"
