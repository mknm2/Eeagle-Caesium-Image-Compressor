        "fileResolutionIsNotEqual": "转换失败，输出结果异常(ERROR_RESOLUTION)",
        "fileSsimAbnormality": "转换失败，输出结果异常(ERROR_SSIM)",
        "fileHistogramsAbnormality": "转换失败，输出结果异常(ERROR_HISTOGRAMS)",
        "fileSizeAbnormality": "转换失败，输出结果异常(ERROR_SIZE)",

        "failedToFetch": "文件访问失败"
