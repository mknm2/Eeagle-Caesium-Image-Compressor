const svgo = require('./lib/svgo.browser');
const fs = require('node:fs');
const url = require('node:url');
const spawn = require('node:child_process').spawn;
const { createFolder } = require('../utils/file');
const path = require('path');

module.exports = class {
    static async compress(src, dist, options, ext) {
        let removeInput;
        try {
            let input = src;

            // NOTE: 好幾個 exe 不支援中文路徑，目前暫時針對 Windows 平台將輸入檔案先複製到系統 temp，以此做為路徑添加
            if (process.platform === 'win32') {
                const tempPath = path.normalize(
                    require('os').tmpdir() + '/' + Math.random().toString(36).substr(2) + '.' + ext
                );
                await fs.promises.copyFile(src, tempPath);
                input = tempPath;
                removeInput = async () => {
                    if (process.platform === 'win32' && input !== src) {
                        if (fs.existsSync(input)) {
                            await fs.promises.rm(input);
                        }
                    }
                };
            }

            eagle.log.info('compressing image Path:' + input);
            const config = getBinaryConfig(input, dist, options);

            // 檢查是否具備執行權限，如果沒有的話幫他加上
            if (process.platform !== 'win32' && ext !== 'svg') {
                try {
                    await fs.promises.access(config.path, fs.constants.X_OK);
                } catch (err) {
                    await fs.promises.chmod(config.path, 755);
                }
            }
            switch (ext) {
                case 'jpg':
                case 'jpeg':
                case 'png':
                case 'webp':
                case 'gif':
                    await spawnPromise(config.path, config.params, 60 * 1000);
                    break;
                case 'svg':
                    await compressSVG(input, dist);
                    break;
                default:
                    throw 'file extension not supported';
            }
            if (removeInput) await removeInput();
        } catch (err) {
            if (fs.existsSync(dist)) {
                await fs.promises.rm(dist);
            }
            if (removeInput) await removeInput();
            throw err;
        }

        eagle.log.info('compressing image down');
    }

    static async createTempFolder(path) {
        await createFolder(path);
    }
};

async function compressSVG(src, dist) {
    try {
        const svgStr = await fs.promises.readFile(src, 'utf-8');
        let compressed = svgo.optimize(svgStr, {});
        await fs.promises.writeFile(dist, compressed.data);
    } catch (err) {
        throw err;
    }
}

function getBinaryConfig(src, dist, options) {
    let postfix = eagle.app.platform === 'win32' ? '.exe' : '';
    let { algorithm, quality } = options;
    let binaryPath = `${eagle.plugin.path}/modules/image-compressor/bin/${algorithm}${postfix}`;
    let binaryParams = '';

    switch (algorithm) {
        case 'mozjpeg':
            binaryParams = ['-quality', quality, '-outfile', dist, src];
            break;
        case 'jpegtran':
            binaryParams = ['-optimize', '-outfile', dist, src];
            break;
        case 'pngquant':
            binaryParams = ['--quality', `${quality}-${quality}`, '-o', dist, src];
            break;
        case 'optipng':
            binaryParams = ['-o2', '-out', dist, src];
            break;
        case 'cwebp':
            binaryParams = ['-q', quality, '-o', dist, src];
            break;
        case 'gifsicle':
            binaryParams = ['-O3', '--output', dist, src];
            break;
        case 'gifsicleLossy':
            binaryParams = ['-O3', `--lossy=${quality}`, '--output', dist, src];
            binaryPath = `${eagle.plugin.path}/modules/image-compressor/bin/gifsicle${postfix}`;
            break;
        case 'svgo':
            break;
        default:
            throw "system doesn't have this algorithm";
    }

    return {
        path: path.normalize(binaryPath),
        params: binaryParams
    };
}

async function spawnPromise(bin, params, timeout) {
    const process = () => {
        return new Promise((resolve, reject) => {
            const cmd = spawn(bin, params, { encoding: 'utf8', timeout: timeout });

            cmd.stdout.on('data', (data) => {
                console.log(`stdout: ${data}`);
            });

            cmd.stderr.on('data', (data) => {
                console.log(`stderr: ${data}`);
            });

            cmd.on('close', (code) => {
                console.log(`process exited with code ${code}`);
                resolve();
            });
        });
    };

    try {
        await process();
    } catch (error) {
        eagle.log.error(`compressing image error : ${error}`);
        throw error;
    }
}
